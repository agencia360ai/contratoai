# =============================================================================
# TeContrato Panamá — Environment variables
# Copy to .env (root), apps/frontend/.env.local, apps/api/.env as needed.
# =============================================================================

# ----- Supabase ----------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Frontend (Next.js public envs)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- AI providers ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# Models (override if needed)
CLAUDE_MODEL_HEAVY=claude-sonnet-4-5-20250929
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ----- Scrapers ----------------------------------------------------------------
SCRAPER_USER_AGENT_POOL=auto
SCRAPER_MAX_PAGES=30
SCRAPER_CONCURRENCY=4
SCRAPER_DELAY_SECONDS=1.2
SCRAPER_TIMEOUT_SECONDS=20

# Proxies (IPRoyal PAYG residential — opcional, solo si te bloquean)
PROXY_PROVIDER=iproyal
PROXY_USER=
PROXY_PASS=
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_COUNTRY=PA

# CAPTCHA (Capsolver)
CAPSOLVER_API_KEY=

# ----- Orchestration -----------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api
REDIS_URL=redis://localhost:6379/0

# ----- Observability -----------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=

# ----- Feature flags -----------------------------------------------------------
ENABLE_GAMIFICATION=true
ENABLE_LEADERBOARDS=true
ENABLE_VOICE_ONBOARDING=false
ENABLE_TELEGRAM_SOURCE=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ----- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="TeContrato Panamá <noreply@tecontrato.pa>"
RESEND_REPLY_TO=hola@tecontrato.pa

# ----- Public intake links -----------------------------------------------------
# Bucket name in Supabase Storage para uploads de intake (creado por migración 0006_storage)
INTAKE_STORAGE_BUCKET=intake-uploads
# Rate limit por IP en submissions/hora
INTAKE_RATE_LIMIT_PER_HOUR=10
# Hash secret para anonimizar IPs en intake_submissions.ip_hash
INTAKE_IP_HASH_SECRET=change-me-to-a-long-random-string

# ----- GitHub Actions cron -----------------------------------------------------
# Estos solo se setean como secrets en el repo (no en .env local)
# SUPABASE_SERVICE_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY ya listados arriba
